# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
#
# .env is gitignored — never commit real credentials.

# ── PostgreSQL (Airflow metadata DB) ──────────────────────────────────────────
POSTGRES_PASSWORD=change_me

# ── Airflow ───────────────────────────────────────────────────────────────────
# Generate a Fernet key:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=change_me

# Any random string, e.g.:  openssl rand -hex 32
AIRFLOW_SECRET_KEY=change_me

AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me
